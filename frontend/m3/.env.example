# Backend Configuration
FLASK_SECRET_KEY=dev_secret_key_fallback
PORT=5000

# Google API Credentials (Service Account)
# Required for Google Sheets integration and GSC
# Option 1: Path to JSON file (Recommended for local dev)
GOOGLE_APPLICATION_CREDENTIALS=backend/gsc_credentials.json

# Option 2: JSON Content directly (Useful for PaaS/Heroku/Render)
# GOOGLE_CREDENTIALS_JSON={"type": "service_account", "project_id": "..."}

# AI Providers (Optional)
OPENAI_API_KEY=sk-...
MISTRAL_API_KEY=...
GEMINI_API_KEY=...
