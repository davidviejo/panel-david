{% extends "base.html" %}

{% block content %}
<div class="container-fluid p-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
            <h2 class="fw-bold"><i class="fab fa-google text-success"></i> Search Console Tracker</h2>
            <p class="text-muted">Rendimiento orgánico real de: <strong>{{ current_project.domain }}</strong></p>
        </div>
        <div>
            <span id="modeBadge" class="badge bg-secondary">Cargando...</span>
            <button class="btn btn-outline-primary btn-sm ms-2" onclick="loadGSC()">
                <i class="fas fa-sync"></i> Actualizar
            </button>
        </div>
    </div>

    <!-- KPIs -->
    <div class="row mb-4">
        <div class="col-md-6">
            <div class="card border-start border-4 border-primary shadow-sm">
                <div class="card-body">
                    <h6 class="text-uppercase text-muted small">Clics (28 días)</h6>
                    <h2 class="fw-bold text-primary mb-0" id="totalClicks">-</h2>
                </div>
            </div>
        </div>
        <div class="col-md-6">
            <div class="card border-start border-4 border-info shadow-sm">
                <div class="card-body">
                    <h6 class="text-uppercase text-muted small">Impresiones</h6>
                    <h2 class="fw-bold text-info mb-0" id="totalImps">-</h2>
                </div>
            </div>
        </div>
    </div>

    <!-- GRÁFICA -->
    <div class="card shadow mb-4">
        <div class="card-header bg-white">
            <h6 class="m-0 fw-bold text-dark">Evolución de Tráfico</h6>
        </div>
        <div class="card-body">
            <div class="chart-area" style="height: 400px;">
                <canvas id="gscChart"></canvas>
            </div>
        </div>
    </div>
    
    <!-- Instrucciones si es DEMO -->
    <div id="demoAlert" class="alert alert-warning d-none">
        <strong>⚠️ Modo Demostración Activo:</strong> No se encontró el archivo <code>gsc_credentials.json</code>. 
        <br>Los datos mostrados son simulados. Para ver datos reales, añade el JSON de Google Cloud en la raíz del proyecto.
    </div>
</div>

<script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
<script>
    document.addEventListener("DOMContentLoaded", function() {
        loadGSC();
    });

    async function loadGSC() {
        try {
            const res = await fetch('/gsc/data', { method: 'POST' });
            const data = await res.json();
            
            if(data.error) {
                alert(data.error);
                return;
            }

            // Actualizar KPIs
            document.getElementById('totalClicks').innerText = data.totals.clicks.toLocaleString();
            document.getElementById('totalImps').innerText = data.totals.impressions.toLocaleString();
            
            // Badge Modo
            const badge = document.getElementById('modeBadge');
            if(data.mode === 'REAL') {
                badge.className = 'badge bg-success';
                badge.innerText = 'CONECTADO API';
                document.getElementById('demoAlert').classList.add('d-none');
            } else {
                badge.className = 'badge bg-warning text-dark';
                badge.innerText = 'SIMULACIÓN';
                document.getElementById('demoAlert').classList.remove('d-none');
            }

            // Renderizar Gráfica
            renderChart(data.chart);

        } catch (e) {
            console.error(e);
        }
    }

    function renderChart(chartData) {
        const ctx = document.getElementById('gscChart').getContext('2d');
        if(window.myChart) window.myChart.destroy();

        window.myChart = new Chart(ctx, {
            type: 'line',
            data: {
                labels: chartData.labels,
                datasets: [
                    {
                        label: 'Clics',
                        data: chartData.clicks,
                        borderColor: '#4e73df',
                        backgroundColor: 'rgba(78, 115, 223, 0.05)',
                        tension: 0.3,
                        yAxisID: 'y',
                        fill: true
                    },
                    {
                        label: 'Impresiones',
                        data: chartData.impressions,
                        borderColor: '#36b9cc',
                        backgroundColor: 'transparent',
                        borderDash: [5, 5],
                        tension: 0.3,
                        yAxisID: 'y1'
                    }
                ]
            },
            options: {
                maintainAspectRatio: false,
                interaction: { mode: 'index', intersect: false },
                scales: {
                    y: { type: 'linear', display: true, position: 'left' },
                    y1: { type: 'linear', display: true, position: 'right', grid: { drawOnChartArea: false } }
                }
            }
        });
    }
</script>
{% endblock %}