# Server Configuration
PORT=5000
FLASK_DEBUG=true

# Database (Leave empty to use SQLite default)
DATABASE_URL=

# Security
JWT_SECRET=change_this_secret_locally
# Plain text passwords will be automatically hashed on startup
CLIENTS_AREA_PASSWORD=demo_client
OPERATOR_PASSWORD=demo_operator

# CORS Configuration
FRONTEND_URL=http://localhost:5173

# External Services (Optional for local dev)
DATAFORSEO_LOGIN=
DATAFORSEO_PASSWORD=
GOOGLE_DEFAULT_COOKIE=
